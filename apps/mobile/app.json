{
  "expo": {
    "name": "Farm Management Mobile Pilot",
    "slug": "farm-management-mobile-pilot",
    "scheme": "farmmanagementmobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.farmmanagementsystem.mobilepilot"
    },
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to record farm voice notes.",
          "recordAudioAndroid": true
        }
      ],
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to add farm photos to local notes.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to take farm photos for local notes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
