{
  "name": "@farm-management-system/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo start --dev-client --android",
    "ios": "expo start --dev-client --ios",
    "build:android:development": "eas build --platform android --profile development",
    "build:android:preview": "eas build --platform android --profile preview",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test .test-build/src"
  },
  "dependencies": {
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-constants": "~18.0.7",
    "expo-dev-client": "~6.0.11",
    "expo-file-system": "~19.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.7",
    "expo-router": "~6.0.0",
    "expo-sharing": "~14.0.7",
    "expo-sqlite": "~16.0.8",
    "expo-status-bar": "~3.0.7",
    "fflate": "^0.8.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "whisper.rn": "^0.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.3"
  }
}
